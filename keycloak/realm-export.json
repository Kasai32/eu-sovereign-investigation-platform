{
  "realm": "platform",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "accessTokenLifespan": 900,
  "roles": {
    "realm": [
      { "name": "analyst" },
      { "name": "supervisor" },
      { "name": "compliance" },
      { "name": "admin" }
    ]
  },
  "clients": [
    {
      "clientId": "platform-api",
      "enabled": true,
      "publicClient": true,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": true,
      "redirectUris": ["http://localhost:3000/*"],
      "webOrigins": ["http://localhost:3000"],
      "protocol": "openid-connect",
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "http://localhost:3000/*"
      }
    }
  ],
  "users": [
    {
      "username": "alice.analyst",
      "email": "alice.analyst@example-bank.test",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Alice",
      "lastName": "Analyst",
      "credentials": [{ "type": "password", "value": "devpassword123", "temporary": false }],
      "realmRoles": ["analyst"]
    },
    {
      "username": "sam.supervisor",
      "email": "sam.supervisor@example-bank.test",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Sam",
      "lastName": "Supervisor",
      "credentials": [{ "type": "password", "value": "devpassword123", "temporary": false }],
      "realmRoles": ["supervisor"]
    },
    {
      "username": "cara.compliance",
      "email": "cara.compliance@example-bank.test",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Cara",
      "lastName": "Compliance",
      "credentials": [{ "type": "password", "value": "devpassword123", "temporary": false }],
      "realmRoles": ["compliance"]
    },
    {
      "username": "adam.admin",
      "email": "adam.admin@example-bank.test",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Adam",
      "lastName": "Admin",
      "credentials": [{ "type": "password", "value": "devpassword123", "temporary": false }],
      "realmRoles": ["admin"]
    }
  ]
}
