# Copy to .env and set real values for any shared or production environment.
# docker-compose reads .env automatically from this directory. Local dev works with no
# .env file at all — everything below falls back to a clearly-labeled placeholder.
#
# These are bootstrap/admin credentials for the two containers, not the app's own runtime
# role (app_user) — see db/migrations/005_roles_and_rls.sql for why that distinction matters.

POSTGRES_SUPERUSER_PASSWORD=postgres_local_dev_only
KEYCLOAK_ADMIN_PASSWORD=admin_local_dev_only

# Passed to db/scripts/migrate.sh to set app_user's password at migration time, without
# rewriting the already-applied migration that first created the role (005). See
# db/migrations/010_configurable_app_user_password.sql.
APP_USER_PASSWORD=app_user_local_dev_only
